Vagrant.configure("2") do |config|
  config.vm.box = "<%= os %>"

<% if (os.includes('kalilinux') && provider === 'virtualbox') { %>
  # Required plugin for Kali Linux guest additions
  if Vagrant.has_plugin?("vagrant-vbguest")
    config.vbguest.auto_update = true
  end
<% } %>

<% if (network === 'bridged') { %>
  config.vm.network "public_network"
<% } else if (network === 'host-only') { %>
  config.vm.network "private_network", type: "dhcp"
<% } else if (network === 'kali-preset') { %>
  # Kali Linux Preset Network Configuration
  # 1. NAT is added by default by Vagrant (eth0)
  # 2. Host-only (for host machine access like Ollama)
  config.vm.network "private_network", type: "dhcp"
<% if (provider === 'virtualbox') { %>
  # 3. Internal network (for isolated lab tools like OpenClaw)
  config.vm.network "private_network", virtualbox__intnet: "kalilab"
<% } %>
<% } %>

  config.vm.provider "<%= provider %>" do |v|
<% if (provider === 'vmware_desktop') { %>
    v.vmx["memsize"] = "<%= ram %>"
    v.vmx["numvcpus"] = "<%= cpu %>"
    v.gui = true
<% } else { %>
    v.memory = <%= ram %>
    v.cpus = <%= cpu %>
<% } %>
<% if (provider === 'virtualbox') { %>
    v.customize ["modifyvm", :id, "--ioapic", "on"]
    v.customize ["showvminfo", :id] # Forces a refresh
<% } %>
  end
end
